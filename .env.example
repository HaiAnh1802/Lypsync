GEMINI_API_KEY=your_gemini_api_key_here

# Giọng đọc Gemini TTS (chọn 1 trong các giọng bên dưới)
# Giọng trầm ấm:  Kore, Charon, Fenrir, Orus
# Giọng trong:    Aoede, Leda, Zephyr, Puck
# Giọng trung:    Achird, Algenib, Algieba, Alnilam
GEMINI_VOICE=Kore
